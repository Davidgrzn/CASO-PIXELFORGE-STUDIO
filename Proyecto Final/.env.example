 POSTGRES_USER=pixelforge
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=pixelforge
DATABASE_URL=postgresql://pixelforge:CHANGE_ME_DB_PASSWORD@db:5432/pixelforge

SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_SECRET_FOR_JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
PARTIAL_TOKEN_EXPIRE_MINUTES=5
TOTP_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY_GENERATED_WITH_Fernet_generate_key
COOKIE_SECURE=false
FRONTEND_ORIGIN=http://localhost

# OAuth2 MFA with Authorization Code + PKCE.
# Google Cloud Console:
# - App type: Web application
# - Authorized redirect URI: http://localhost/api/mfa/oauth2/callback
# - The Google account email must match the PixelForge user email.
OAUTH2_PROVIDER=google
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
OAUTH2_TOKEN_URL=https://oauth2.googleapis.com/token
OAUTH2_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
OAUTH2_REDIRECT_URI=http://localhost/api/mfa/oauth2/callback
OAUTH2_SCOPES=openid email profile

# Microsoft Entra ID alternative:
# OAUTH2_PROVIDER=microsoft
# OAUTH2_AUTH_URL=https://login.microsoftonline.com/common/oauth2/v2.0/authorize
# OAUTH2_TOKEN_URL=https://login.microsoftonline.com/common/oauth2/v2.0/token
# OAUTH2_USERINFO_URL=https://graph.microsoft.com/oidc/userinfo
# OAUTH2_SCOPES=openid email profile
